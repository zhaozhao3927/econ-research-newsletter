<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Behavioral & Experimental Economics Weekly</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 2rem; background: #f6f3ed; color: #222; }
    .issue { background: #fff; border: 1px solid #ddd; padding: 1rem; border-radius: 8px; margin: 0.75rem 0; }
  </style>
</head>
<body>
  <h1>Behavioral & Experimental Economics Weekly</h1>
  <p>Archive of generated issues.</p>
  {% for issue in issues %}
  <div class="issue">
    <a href="issues/becon-weekly-{{ issue.publishDate }}.html">Issue #{{ issue.issueNumber }} - {{ issue.publishDate }}</a>
    <div>{{ issue.papers|length }} papers</div>
  </div>
  {% else %}
  <p>No issues yet. Run the weekly script first.</p>
  {% endfor %}
</body>
</html>
